# ─── LLM providers ─────────────────────────────────────────────
# Required: Claude is the primary reasoning model (Intake, Policy, Counsel)
ANTHROPIC_API_KEY=

# Required: Groq is the fast structured-output model (Risk scorer)
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Required only if Member B ships pgvector RAG (for embeddings)
# Get a key at https://platform.openai.com
OPENAI_API_KEY=

# ─── Supabase ──────────────────────────────────────────────────
# Project URL + anon key — get from Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_KEY=

# Postgres connection string — get from Supabase dashboard → Project Settings →
# Database → Connection string → "URI" tab → use the "Transaction" pooler port (6543)
# or "Session" pooler (5432). Replace [YOUR-PASSWORD] with your actual DB password.
# Example: postgresql://postgres.abcdefgh:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# ─── LangSmith observability ───────────────────────────────────
# Sign up at https://smith.langchain.com — free tier is fine
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=hireguard-v2

# ─── Tavily (optional, 2nd external API for statute freshness check) ──
# Get a free key at https://tavily.com
TAVILY_API_KEY=
